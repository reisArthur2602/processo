// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client"
    output   = "../app/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum CaseStatus {
    ACTIVE
    SUSPENDED
    ARCHIVED
}

enum PartyType {
    PLAINTIFF
    DEFENDANT
    OTHER
}

enum PersonType {
    INDIVIDUAL
    COMPANY
}

enum DeadlineStatus {
    PENDING
    COMPLETED
    CANCELED
}

enum InviteStatus {
    PENDING
    ACCEPTED
    EXPIRED
    CANCELED
}

model User {
    id           String  @id @default(uuid())
    name         String
    username     String  @unique
    passwordHash String
    admin        Boolean @default(false)
    isActive     Boolean @default(true)

    responsibleCases Case[]     @relation("ResponsibleLawyer")
    createdCases     Case[]     @relation("CaseCreator")
    movements        Movement[]
    documents        Document[]
    deadlines        Deadline[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([username])
    @@index([isActive])
}

model Case {
    id          String     @id @default(uuid())
    number      String     @unique
    title       String
    actionType  String
    court       String
    division    String?
    claimValue  Decimal?   @db.Decimal(12, 2)
    status      CaseStatus @default(ACTIVE)
    description String?    @db.Text

    responsibleLawyerId String
    responsibleLawyer   User   @relation("ResponsibleLawyer", fields: [responsibleLawyerId], references: [id])

    createdById String
    createdBy   User   @relation("CaseCreator", fields: [createdById], references: [id])

    parties   Party[]
    movements Movement[]
    documents Document[]
    deadlines Deadline[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([number])
    @@index([status])
    @@index([responsibleLawyerId])
    @@index([createdById])
    @@index([updatedAt])
}

model Party {
    id         String     @id @default(uuid())
    name       String
    document   String?
    partyType  PartyType
    personType PersonType @default(INDIVIDUAL)

    caseId String
    case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([caseId])
    @@index([partyType])
    @@index([document])
}

model Movement {
    id           String   @id @default(uuid())
    title        String
    movementType String   @default("Registro interno")
    description  String?  @db.Text
    occurredAt   DateTime

    caseId String
    case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

    createdById String
    createdBy   User   @relation(fields: [createdById], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([caseId])
    @@index([createdById])
    @@index([occurredAt])
}

model Document {
    id           String @id @default(uuid())
    name         String
    originalName String
    path         String
    mimeType     String
    size         Int

    caseId String
    case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

    uploadedById String
    uploadedBy   User   @relation(fields: [uploadedById], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([caseId])
    @@index([uploadedById])
}

model Deadline {
    id          String         @id @default(uuid())
    title       String
    description String?        @db.Text
    dueAt       DateTime
    status      DeadlineStatus @default(PENDING)
    completedAt DateTime?

    caseId String
    case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

    assignedToId String
    assignedTo   User   @relation(fields: [assignedToId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([caseId])
    @@index([assignedToId])
    @@index([status])
    @@index([dueAt])
}
