// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client"
    output   = "../app/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum PersonType {
    INDIVIDUAL
    COMPANY
}

enum ClientStatus {
    ACTIVE
    INACTIVE
    PROSPECT
}

enum CaseStatus {
    ACTIVE
    SUSPENDED
    ARCHIVED
    CLOSED
}

enum PartyType {
    PLAINTIFF
    DEFENDANT
    OTHER
}

enum IntakeStatus {
    DRAFT
    OPEN
    FINALIZED
    CONVERTED
    CANCELED
}

enum ProvidenceType {
    REQUEST_DOCUMENTS
    PREPARE_LEGAL_OPINION
    SCHEDULE_RETURN
    PREPARE_CONTRACT
    FILE_LAWSUIT
    SETTLEMENT_ATTEMPT
    OTHER
}

enum DeadlineStatus {
    PENDING
    COMPLETED
    CANCELED
}

enum AppointmentType {
    HEARING
    MEETING
    RETURN
    DEADLINE
    OTHER
}

enum AppointmentStatus {
    SCHEDULED
    COMPLETED
    CANCELED
}

enum PaymentMethod {
    CASH
    PIX
    BANK_TRANSFER
    CREDIT_CARD
    DEBIT_CARD
    BOLETO
    INSTALLMENTS
    OTHER
}

enum DocumentCategory {
    POWER_OF_ATTORNEY
    CONTRACT
    PETITION
    DECISION
    ID_DOCUMENT
    PROOF
    REPORT
    OTHER
}

enum InviteStatus {
    PENDING
    ACCEPTED
    EXPIRED
    CANCELED
}

model User {
    id           String  @id @default(uuid())
    name         String
    username     String  @unique
    passwordHash String
    admin        Boolean @default(false)
    isActive     Boolean @default(true)

    createdClients      Client[]      @relation("ClientCreator")
    responsibleClients  Client[]      @relation("ClientResponsible")
    responsibleCases    Case[]        @relation("ResponsibleLawyer")
    createdCases        Case[]        @relation("CaseCreator")
    responsibleIntakes  Intake[]      @relation("IntakeResponsible")
    createdIntakes      Intake[]      @relation("IntakeCreator")
    movements           Movement[]
    uploadedDocuments   Document[]    @relation("DocumentUploader")
    deletedDocuments    Document[]    @relation("DocumentDeleter")
    deadlines           Deadline[]
    appointments        Appointment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([username])
    @@index([isActive])
}

model Client {
    id         String       @id @default(uuid())
    personType PersonType  @default(INDIVIDUAL)
    status     ClientStatus @default(PROSPECT)

    name       String
    document   String?      @unique
    rg         String?
    birthDate  DateTime?
    maritalStatus String?
    profession String?

    phone String?
    email String?

    zipCode      String?
    street       String?
    number       String?
    complement   String?
    district     String?
    city         String?
    state        String?

    notes String? @db.Text

    responsibleId String?
    responsible   User?   @relation("ClientResponsible", fields: [responsibleId], references: [id])

    createdById String
    createdBy   User   @relation("ClientCreator", fields: [createdById], references: [id])

    intakes Intake[]
    cases   Case[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([name])
    @@index([document])
    @@index([phone])
    @@index([email])
    @@index([status])
    @@index([responsibleId])
    @@index([createdById])
    @@index([updatedAt])
}

model Intake {
    id     String       @id @default(uuid())
    number String       @unique
    status IntakeStatus @default(OPEN)

    serviceArea String

    clientReport String? @db.VarChar(1800)
    preliminaryAnalysis String? @db.VarChar(1800)

    providences ProvidenceType[] @default([])
    otherProvidence String? @db.Text

    requestedDocuments String[] @default([])

    feeAmount      Decimal? @db.Decimal(12, 2)
    amountReceived Decimal? @db.Decimal(12, 2)
    paymentMethod  PaymentMethod?
    paymentNotes   String? @db.Text

    attendedAt DateTime @default(now())
    finalizedAt DateTime?

    clientId String
    client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

    caseId String?
    case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

    responsibleId String
    responsible   User   @relation("IntakeResponsible", fields: [responsibleId], references: [id])

    createdById String
    createdBy   User   @relation("IntakeCreator", fields: [createdById], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([number])
    @@index([status])
    @@index([serviceArea])
    @@index([clientId])
    @@index([caseId])
    @@index([responsibleId])
    @@index([createdById])
    @@index([attendedAt])
}

model Case {
    id String @id @default(uuid())

    number String? @unique
    title  String

    serviceArea String
    actionType  String?

    court        String?
    division     String?
    district     String?
    currentPhase String?

    claimValue  Decimal?   @db.Decimal(12, 2)
    status      CaseStatus @default(ACTIVE)
    description String?    @db.Text

    clientId String
    client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

    responsibleLawyerId String
    responsibleLawyer   User   @relation("ResponsibleLawyer", fields: [responsibleLawyerId], references: [id])

    createdById String
    createdBy   User   @relation("CaseCreator", fields: [createdById], references: [id])

    intakes      Intake[]
    parties      Party[]
    movements    Movement[]
    documents    Document[]
    deadlines    Deadline[]
    appointments Appointment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([number])
    @@index([title])
    @@index([serviceArea])
    @@index([status])
    @@index([clientId])
    @@index([responsibleLawyerId])
    @@index([createdById])
    @@index([updatedAt])
}

model Party {
    id         String     @id @default(uuid())
    name       String
    document   String?
    partyType  PartyType
    personType PersonType @default(INDIVIDUAL)

    caseId String
    case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([caseId])
    @@index([partyType])
    @@index([document])
}

model Movement {
    id           String   @id @default(uuid())
    title        String
    movementType String   @default("Registro interno")
    description  String?  @db.Text
    occurredAt   DateTime

    caseId String
    case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

    createdById String
    createdBy   User   @relation(fields: [createdById], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([caseId])
    @@index([createdById])
    @@index([occurredAt])
}

model Document {
    id           String @id @default(uuid())
    name         String
    originalName String
    path         String
    mimeType     String
    size         Int
    category     DocumentCategory @default(OTHER)

    caseId String
    case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

    uploadedById String
    uploadedBy   User   @relation("DocumentUploader", fields: [uploadedById], references: [id])

    deletedAt DateTime?
    deletedById String?
    deletedBy   User?   @relation("DocumentDeleter", fields: [deletedById], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([caseId])
    @@index([uploadedById])
    @@index([deletedById])
    @@index([category])
    @@index([deletedAt])
}

model Deadline {
    id          String         @id @default(uuid())
    title       String
    description String?        @db.Text
    dueAt       DateTime
    status      DeadlineStatus @default(PENDING)
    completedAt DateTime?

    caseId String
    case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

    assignedToId String
    assignedTo   User   @relation(fields: [assignedToId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([caseId])
    @@index([assignedToId])
    @@index([status])
    @@index([dueAt])
}

model Appointment {
    id          String            @id @default(uuid())
    title       String
    type        AppointmentType   @default(OTHER)
    status      AppointmentStatus @default(SCHEDULED)
    description String?           @db.Text

    startsAt DateTime
    endsAt   DateTime?
    location String?

    caseId String
    case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

    responsibleId String
    responsible   User   @relation(fields: [responsibleId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([caseId])
    @@index([responsibleId])
    @@index([type])
    @@index([status])
    @@index([startsAt])
}
