# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/processo?schema=public"

# ─── Autenticação ─────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Gere com: openssl rand -base64 32
JWT_SECRET="sua-chave-secreta-com-pelo-menos-32-caracteres"

# ─── URL pública da aplicação ─────────────────────────────────────────────────
NEXT_PUBLIC_URL="https://processo.exemplo.com.br"

# ─── FTP ──────────────────────────────────────────────────────────────────────
FTP_HOST="ftp.exemplo.com.br"
FTP_PORT="21"
FTP_USER="usuario-ftp"
FTP_PASSWORD="senha-ftp"
FTP_SECURE="false"
FTP_BASE_PATH="/processo"

# ─── SMTP (envio de e-mail) ───────────────────────────────────────────────────
SMTP_HOST="smtp.exemplo.com.br"
SMTP_PORT="587"
SMTP_USER="usuario@exemplo.com.br"
SMTP_PASSWORD="senha-smtp"
SMTP_FROM="Sistema Jurídico <noreply@exemplo.com.br>"
SMTP_SECURE="false"

# ─── Seed ─────────────────────────────────────────────────────────────────────
# Usado apenas no comando: npx prisma db seed
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="troque-esta-senha"
